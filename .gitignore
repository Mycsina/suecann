# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

**/target/**
.*/
# ...but DO track the committed WASM pre-commit hook. Without these negations the
# `.*/` rule above swallows code/.githooks/, so the documented
# `git config core.hooksPath code/.githooks` would point at an empty dir on fresh clones.
!code/.githooks/
!code/.githooks/pre-commit
checkpoints/
*.csv
*.data
*.log
GEMINI.md
/pgo-data/

# Exclude github files
!/.github